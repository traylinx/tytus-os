{
  "name": "tytus-os",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Tytus OS \u2014 desktop shell for your private AI pod.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "typecheck:guard": "tsc --noEmit -p tsconfig.guard.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke.mjs",
    "test:probe": "node scripts/probe-phase2.mjs",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "bundle:check:strict": "node scripts/check-bundle-budget.mjs --strict",
    "audit:bundle-strict": "node scripts/check-bundle-budget.mjs --strict",
    "audit:radius": "node scripts/audit-radius.mjs",
    "i18n:check": "node scripts/i18n-check.mjs",
    "i18n:update-allowlist": "node scripts/i18n-check.mjs --write-allowlist"
  },
  "dependencies": {
