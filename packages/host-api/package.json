{
  "name": "@tytus/host-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Typed Host API contract that Tytus apps consume.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "node bin/tytus-app.mjs"
  },
  "bin": {
    "tytus-app": "./bin/tytus-app.mjs"
  },
  "dependencies": {
    "@tytus/contracts": "*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
