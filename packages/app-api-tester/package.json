{
  "name": "@tytus/app-api-tester",
  "version": "0.1.0-skeleton",
  "private": true,
  "type": "module",
  "description": "API Tester — user-installable Tytus app. Postman-style HTTP request builder with history, environments, and response viewer. Will be carved into its own git repo (tytus-app-api-tester) post-skeleton.",
  "main": "./src/index.tsx",
  "types": "./src/index.tsx",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx"
    }
  },
  "scripts": {
    "build": "vite build --config ../../vite.lib.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@tytus/host-api": "*",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "typescript": "~5.9.3"
  }
}
