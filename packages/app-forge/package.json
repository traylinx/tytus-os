{
  "name": "@tytus/app-forge",
  "version": "0.1.0-mvp",
  "private": true,
  "type": "module",
  "description": "Tytus Forge — bundled Tytus OS workbench powered by Monaco, ready for local files and future agent/Cortex workflows.",
  "main": "./src/index.tsx",
